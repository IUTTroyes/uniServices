{
    "name": "uniservices-monorepo",
    "private": true,
    "description": "Monorepo for uniServices Symfony Bundles",
    "workspaces": [
        "packages/*",
        "shared/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:auth\" \"npm run dev:edt\" \"npm run dev:helpdesk\" \"npm run dev:intranet\" \"npm run dev:questionnaire\" \"npm run dev:stage\" \"npm run dev:unifolio\"",
        "dev:auth": "cd packages/auth-bundle && vite --port 3000 --open",
        "dev:intranet": "cd packages/intranet-bundle && vite --port 3001",
        "dev:edt": "cd packages/edt-bundle && vite --port 3003",
        "dev:unifolio": "cd packages/unifolio-bundle && vite --port 3002",
        "build:auth": "cd packages/auth-bundle && vite build",
        "build:edt": "cd packages/edt-bundle && vite build",
        "build:intranet": "cd packages/intranet-bundle && vite build",
        "build:unifolio": "cd packages/unifolio-bundle && vite build",
        "dev:helpdesk": "cd packages/helpdesk-bundle && vite --port 3004",
        "build:helpdesk": "cd packages/helpdesk-bundle && vite build",
        "dev:questionnaire": "cd packages/questionnaire-bundle && vite --port 3005",
        "build:questionnaire": "cd packages/questionnaire-bundle && vite build",
        "dev:stage": "cd packages/stage-bundle && vite --port 3006",
        "build:stage": "cd packages/stage-bundle && vite build"
    },
    "devDependencies": {
        "@primeuix/themes": "^2.0.3",
        "@primevue/auto-import-resolver": "^4.5.5",
        "@vitejs/plugin-vue": "^6.0.7",
        "axios": "^1.16.1",
        "pinia": "^3.0.4",
        "primevue": "^4.5.5",
        "sass": "^1.100.0",
        "unplugin-vue-components": "^31.1.0",
        "vite": "^6.4.2",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "dependencies": {
        "@faker-js/faker": "^10.4.0",
        "@headlessui/vue": "^1.7.23",
        "@heroicons/vue": "^2.2.0",
        "@primevue/core": "^4.5.5",
        "@primevue/forms": "^4.5.5",
        "@rushstack/eslint-patch": "^1.16.1",
        "@tailwindcss/vite": "^4.3.0",
        "@vee-validate/yup": "^4.15.1",
        "@vue/eslint-config-prettier": "^10.2.0",
        "autoprefixer": "^10.5.0",
        "chart.js": "^4.5.1",
        "concurrently": "^9.2.1",
        "cypress": "^15.16.0",
        "date-fns": "^4.4.0",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.1",
        "jsdom": "^29.1.1",
        "luxon": "^3.7.2",
        "marked": "^18.0.4",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "primeicons": "^7.0.0",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.3.0",
        "tailwindcss-primeui": "^0.6.1",
        "uuid": "^13.0.2",
        "vee-validate": "^4.15.1",
        "vitest": "^4.1.7",
        "vue-cal": "5.0.1-rc.46",
        "vue-chartjs": "^5.3.3",
        "vue-draggable-next": "^2.3.0",
        "yup": "^1.7.1"
    },
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
