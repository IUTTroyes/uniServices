{
    "name": "uniservices-monorepo",
    "private": true,
    "description": "Monorepo for uniServices Symfony Bundles",
    "workspaces": [
        "packages/*",
        "shared/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:auth\" \"npm run dev:edt\" \"npm run dev:helpdesk\" \"npm run dev:intranet\" \"npm run dev:unifolio\"",
        "dev:auth": "cd packages/auth-bundle && vite --port 3000 --open",
        "dev:intranet": "cd packages/intranet-bundle && vite --port 3001",
        "dev:edt": "cd packages/edt-bundle && vite --port 3003",
        "dev:unifolio": "cd packages/unifolio-bundle && vite --port 3002",
        "build:auth": "cd packages/auth-bundle && vite build",
        "build:edt": "cd packages/edt-bundle && vite build",
        "build:intranet": "cd packages/intranet-bundle && vite build",
        "build:unifolio": "cd packages/unifolio-bundle && vite build",
        "dev:helpdesk": "cd packages/helpdesk-bundle && vite --port 3004",
        "build:helpdesk": "cd packages/helpdesk-bundle && vite build"
    },
    "devDependencies": {
        "@primevue/auto-import-resolver": "^4.5.4",
        "@primeuix/themes": "^2.0.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "axios": "^1.13.6",
        "pinia": "^3.0.4",
        "primevue": "^4.5.4",
        "sass": "^1.98.0",
        "unplugin-vue-components": "^31.0.0",
        "vite": "^6.4.1",
        "vite-plugin-vue-devtools": "^8.1.0",
        "vue": "^3.5.0",
        "vue-router": "^5.0.4"
    },
    "dependencies": {
        "@chromatic-com/storybook": "^3.2.7",
        "@faker-js/faker": "^10.3.0",
        "@headlessui/vue": "^1.7.23",
        "@heroicons/vue": "^2.2.0",
        "@primevue/core": "^4.3.2",
        "@primevue/forms": "^4.2.5",
        "@rushstack/eslint-patch": "^1.16.1",
        "@storybook/addon-a11y": "^8.6.18",
        "@storybook/addon-essentials": "^8.6.18",
        "@storybook/addon-interactions": "^8.6.18",
        "@storybook/addon-onboarding": "^8.6.18",
        "@storybook/blocks": "^8.6.18",
        "@storybook/test": "^8.6.18",
        "@storybook/vue3": "^8.6.18",
        "@storybook/vue3-vite": "^8.6.18",
        "storybook": "^8.6.18",
        "@tailwindcss/vite": "^4.2.2",
        "@vee-validate/yup": "^4.15.1",
        "@vue/eslint-config-prettier": "^10.2.0",
        "autoprefixer": "^10.4.27",
        "chart.js": "^4.5.1",
        "concurrently": "^9.2.1",
        "cypress": "^15.12.0",
        "date-fns": "^4.1.0",
        "eslint": "^10.1.0",
        "eslint-plugin-storybook": "^0.11.6",
        "eslint-plugin-vue": "^10.8.0",
        "http-proxy-middleware": "^3.0.5",
        "jsdom": "^29.0.1",
        "luxon": "^3.7.2",
        "marked": "^17.0.5",
        "mocha": "^11.7.5",
        "mochawesome": "^7.1.4",
        "mochawesome-merge": "^5.1.1",
        "mochawesome-report-generator": "^6.3.2",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "primeicons": "^7.0.0",
        "rimraf": "^6.1.3",
        "rxjs": "^7.8.2",
        "tailwindcss": "^4.2.2",
        "tailwindcss-primeui": "^0.6.1",
        "uuid": "^13.0.0",
        "vee-validate": "^4.15.1",
        "vitest": "^4.1.0",
        "vue-cal": "^5.0.1-rc.25",
        "vue-chartjs": "^5.3.3",
        "vue-draggable-next": "^2.3.0",
        "yup": "^1.7.1"
    }
}