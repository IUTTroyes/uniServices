{% extends 'emails/layout.html.twig' %}

{% block subject %}Invitation au questionnaire : {{ questionnaire.titre }}{% endblock %}

{% block preheader %}{{ questionnaire.titre }} – Cliquez pour répondre au questionnaire.{% endblock %}

{% block body %}
    <h1>Vous avez reçu une invitation</h1>

    <p>Bonjour,</p>

    <p>
        Vous avez été invité(e) à répondre au questionnaire suivant :
    </p>

    <h2 style="color:#1a3a5c;">{{ questionnaire.titre }}</h2>

    {% if questionnaire.description %}
    <p style="color:#718096;font-style:italic;">{{ questionnaire.description }}</p>
    {% endif %}

    <p>
        <a href="{{ surveyUrl }}" class="btn">Répondre au questionnaire</a>
    </p>

    {% if expiresAt is defined and expiresAt %}
    <div class="alert">
        Cette invitation est valide jusqu'au <strong>{{ expiresAt|date('d/m/Y') }}</strong>.
    </div>
    {% endif %}

    <hr class="divider">

    <p style="font-size:13px;color:#718096;">
        Si le bouton ne fonctionne pas, copiez-collez ce lien dans votre navigateur :<br>
        <a href="{{ surveyUrl }}" style="word-break:break-all;">{{ surveyUrl }}</a>
    </p>

    <p style="font-size:13px;color:#718096;">
        Si vous pensez avoir reçu cet email par erreur, vous pouvez l'ignorer.
    </p>
{% endblock %}
