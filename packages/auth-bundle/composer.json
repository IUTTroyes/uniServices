{
  "name": "iuttroyes/auth-bundle",
  "type": "symfony-bundle",
  "description": "Auth app bundle for uniServices",
  "require": {
    "php": "^8.2",
    "symfony/framework-bundle": "^7.0",
    "symfony/http-kernel": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "AuthBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AuthBundle\\Tests\\": "tests/"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.0.*"
    }
  }
}
