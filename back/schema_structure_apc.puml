}
entity structure_calendrier {
* id: integer
--
 annee_universitaire_id: integer
* semaine_formation: integer
* semaine_reelle: integer
* date_lundi: datetime
}
entity structure_departement {
* id: integer
--
* libelle: string
 logo_name: string
 tel_contact: string
 couleur: string
 site_web: string
 description: text
* actif: boolean
* uuid: uuid
* created: datetime_immutable
 updated: datetime
* opt: json
 old_id: integer
}
entity structure_departement_personnel {
* id: integer
--
* personnel_id: integer
 departement_id: integer
* roles: json
* defaut: boolean
* affectation: boolean
}
entity structure_diplome {
* id: integer
--
 responsable_diplome_id: integer
 assistant_diplome_id: integer
 parent_id: integer
