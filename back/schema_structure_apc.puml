* valid: datetime
}
entity scol_enseignement_apc_apprentissage_critique {
* scol_enseignement_id: integer
* apc_apprentissage_critique_id: integer
--
}
entity scol_evaluation_personnel {
* scol_evaluation_id: integer
* personnel_id: integer
--
}
entity stage_periode_structure_semestre {
* stage_periode_id: integer
* structure_semestre_id: integer
--
}
entity structure_annee {
* id: integer
--
 niveau_id: integer
 pn_id: integer
* libelle: string
* ordre: integer
 libelle_long: string
* actif: boolean
 couleur: string
 apogee_code_version: string
 apogee_code_etape: string
