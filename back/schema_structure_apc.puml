 updated: datetime
* opt: json
 old_id: integer
}
entity structure_groupe {
* id: integer
--
 parent_id: integer
 parcours_id: integer
* libelle: string
* type: string
 ordre: integer
 code_apogee: string
 key_edu_sign: string
 old_id: integer
}
entity structure_groupe_structure_semestre {
* structure_groupe_id: integer
* structure_semestre_id: integer
--
}
entity structure_pn {
* id: integer
--
 diplome_id: integer
 annee_universitaire_id: integer
 apc_referentiel_id: integer
* libelle: string
* annee_publication: integer
}
entity structure_semestre {
* id: integer
--
 annee_id: integer
* libelle: string
* ordre_annee: integer
* ordre_lmd: integer
* actif: boolean
* nb_groupes_cm: integer
* nb_groupes_td: integer
* nb_groupes_tp: integer
 code_element: string
* created: datetime_immutable
 updated: datetime
* opt: json
 key_edu_sign: string
 old_id: integer
}
entity structure_type_diplome {
* id: integer
--
* libelle: string
* sigle: string
* apc: boolean
}
entity structure_ue {
* id: integer
--
 competence_id: integer
 semestre_id: integer
* libelle: string
* numero: integer
* nb_ects: float
* actif: boolean
* bonification: boolean
* code_element: string
 old_id: integer
}
apc_apprentissage_critique }o--o| apc_niveau
apc_competence }o--o| apc_referentiel
apc_niveau }o--o| apc_competence
apc_niveau_apc_parcours }o--|| apc_parcours
apc_niveau_apc_parcours }o--|| apc_niveau
apc_referentiel }o--o| structure_type_diplome
apc_referentiel }o--o| structure_departement
etudiant_scolarite_semestre_structure_groupe }o--|| structure_groupe
etudiant_scolarite_structure_annee }o--|| structure_annee
etudiant_structure_groupe }o--|| structure_groupe
scol_enseignement_apc_apprentissage_critique }o--|| apc_apprentissage_critique
stage_periode_structure_semestre }o--|| structure_semestre
structure_annee }o--o| structure_pn
structure_annee }o--o| apc_niveau
structure_calendrier }o--o| structure_annee_universitaire
structure_departement_personnel }o--o| structure_departement
structure_diplome }o--o| structure_type_diplome
structure_diplome }o--o| apc_parcours
structure_diplome }o--o| structure_diplome
structure_diplome }o--o| apc_referentiel
structure_diplome }o--o| structure_departement
structure_groupe }o--o| apc_parcours
structure_groupe }o--o| structure_groupe
structure_groupe_structure_semestre }o--|| structure_semestre
structure_groupe_structure_semestre }o--|| structure_groupe
structure_pn }o--o| structure_diplome
structure_pn }o--o| structure_annee_universitaire
structure_pn }o--o| apc_referentiel
structure_semestre }o--o| structure_annee
structure_ue }o--o| apc_competence
structure_ue }o--o| structure_semestre
